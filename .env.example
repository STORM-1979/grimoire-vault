# ============================================================
#  Grimoire Vault — environment variables
#  Copy this file to .env.local (never commit .env.local).
# ============================================================

# ---- Supabase ----
# Create a project at https://supabase.com → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...replace_with_anon_key

# Service-role key — only used in trusted server routes (Telegram webhook,
# cron jobs). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...replace_with_service_role_key

# Optional: Supavisor pooler URL for direct Postgres connections (port 6543,
# transaction mode). Only needed if a route uses raw SQL via postgres-js / pg
# instead of the Supabase JS REST client. Project Settings → Database → Connection pooler.
# SUPABASE_DB_POOLER_URL=postgres://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ---- Cloudflare R2 (Phase 2) ----
# Create an R2 bucket at https://dash.cloudflare.com → R2.
# CLOUDFLARE_R2_ACCOUNT_ID=xxxxxxxxxxxx
# CLOUDFLARE_R2_ACCESS_KEY_ID=xxxxxxxxxxxx
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLOUDFLARE_R2_BUCKET=grimoire-vault
# CLOUDFLARE_R2_PUBLIC_BASE=https://pub-xxxxxxx.r2.dev

# ---- Telegram bot (Phase 4) ----
# Get a token from @BotFather. Webhook secret prevents impersonation.
# TELEGRAM_BOT_TOKEN=1234567890:AAAxxx
# TELEGRAM_WEBHOOK_SECRET=any-long-random-string-32+chars

# ---- AI / embeddings (Phase 5) ----
# Get a key at https://anthropic.com/api or https://www.voyageai.com.
# ANTHROPIC_API_KEY=sk-ant-...
# VOYAGE_API_KEY=pa-...

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: email of the sole owner.  When set, /api/admin/stats and the
# AdminStats panel in /settings become available exclusively to a session
# whose email matches this value.  Anyone else gets 403, even if signed in.
# Leave unset to disable owner-only routes entirely (fail-closed).
# OWNER_EMAIL=you@example.com

# Optional: Upstash Redis-backed rate limiter (sliding window, consistent
# across function instances).  Without these, the in-memory token-bucket
# fallback runs and is fine for personal use.  Sign up at https://upstash.com
# (free tier: 10k commands/day, plenty for a personal vault).
# UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AYAAA...

# Web Push (VAPID) — for native-style notifications on Android, iOS PWA,
# desktop.  Generate via: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key MUST be also exposed as NEXT_PUBLIC_VAPID_PUBLIC_KEY (same
# value).  Without these, /settings → Push toggle reports "not configured".
# VAPID_PUBLIC_KEY=BDQ09...
# VAPID_PRIVATE_KEY=kXS9...
# VAPID_SUBJECT=mailto:you@example.com
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BDQ09...
