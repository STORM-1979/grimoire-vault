{
  "manifest_version": 3,
  "name": "Grimoire Vault Clipper",
  "version": "1.0.0",
  "description": "Сохраняй любую страницу в свой Grimoire Vault одним кликом.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://grimoire-vault.vercel.app/*"],
  "background": {
    "service_worker": "background.js"
  }
}
